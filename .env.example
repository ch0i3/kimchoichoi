# 온라인 도량 — Supabase Realtime (anon key만 사용)
# 이 파일을 복사해 .env 로 만들고 값을 채우세요:  cp .env.example .env
#
# Supabase 대시보드 → Project Settings → API 에서 확인:
#   Project URL      → VITE_SUPABASE_URL
#   anon public key  → VITE_SUPABASE_ANON_KEY  (공개돼도 되는 키)

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# 주의: service_role key 는 절대 프론트/깃에 넣지 마세요.
